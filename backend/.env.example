# MongoDB Atlas connection string.
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/blockseat

# JWT signing key for auth middleware.
JWT_SECRET=replace_with_super_secret_jwt_key

# AES-256 secret used by crypto-js for private key encryption.
MASTER_ENCRYPTION_KEY=replace_with_master_encryption_key_32_chars

# Polygon Amoy RPC URL from Alchemy/Infura/QuickNode.
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your-key

# Deployed contract address of BlockSeatTicket.sol.
CONTRACT_ADDRESS=0xYourContractAddress

# Admin wallet private key that owns the contract and executes admin calls.
ADMIN_PRIVATE_KEY=0xYourAdminPrivateKey

# Razorpay test credentials.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# CAPTCHA gate for OTP send endpoint.
CAPTCHA_ENABLED=true
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key

# Redis connection string for the checkout waiting room.
# Leave empty for local fallback, but set in production.
REDIS_URL=redis://localhost:6379

# JWT secret used for short-lived queue passes.
QUEUE_PASS_SECRET=replace_with_queue_pass_secret

# Maximum number of concurrent checkout passes allowed in the waiting room.
QUEUE_MAX_ACTIVE_CHECKOUTS=25

# Per-minute abuse limits for queue endpoints.
QUEUE_JOIN_RATE_LIMIT=30
QUEUE_STATUS_RATE_LIMIT=120

# Queue pass and waiting entry TTLs, in seconds.
QUEUE_PASS_TTL_SECONDS=180
QUEUE_WAIT_TTL_SECONDS=1800

# Minimum interval between status polls for a given user/queue entry.
QUEUE_STATUS_MIN_POLL_MS=1500

# Issuer label for TOTP generation and gate validation.
TOTP_ISSUER=BlockSeat

# Comma-separated allowed CORS origins (defaults to localhost:3000,3001).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Environment mode: development or production.
NODE_ENV=development
